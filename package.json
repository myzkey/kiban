{
  "name": "kiban",
  "version": "0.1.0",
  "description": "An AI-friendly local development stack manager.",
  "type": "module",
  "bin": {
    "kiban": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "commitlint": "commitlint",
    "dev": "tsx src/cli.ts",
    "prepare": "husky",
    "smoke": "pnpm build && node dist/cli.js --help",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "local-development",
    "docker",
    "ports",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.1",
    "fs-extra": "^11.2.0",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.12",
    "husky": "^9.1.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
