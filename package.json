{
  "name": "kiban",
  "version": "0.1.0",
  "description": "An AI-friendly local development stack manager.",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "bin": {
    "kiban": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "commitlint": "commitlint",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "docs:build": "rspress build",
    "docs:dev": "rspress dev",
    "docs:preview": "rspress preview",
    "dev": "tsx src/cli.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "prepare": "husky",
    "smoke": "pnpm build && node scripts/smoke-local-http.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "local-development",
    "docker",
    "ports",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.3.1",
    "fs-extra": "^11.2.0",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@rspress/core": "^2.0.14",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.13.2",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=24"
  }
}
