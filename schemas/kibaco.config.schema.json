{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kibaco.dev/schemas/kibaco.config.schema.json",
  "title": "Kibaco Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "proxyPort": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535,
      "default": 8080
    },
    "log": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxBytes": {
          "type": "integer",
          "minimum": 1,
          "default": 5242880
        },
        "maxFiles": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/project"
      },
      "default": []
    },
    "services": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/service"
      },
      "default": []
    }
  },
  "required": ["proxyPort", "projects", "services"],
  "$defs": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "host": {
          "type": "string",
          "minLength": 1,
          "examples": ["web.localhost"]
        },
        "target": {
          "type": "string",
          "format": "uri",
          "examples": ["http://localhost:3000"]
        },
        "command": {
          "type": "string",
          "minLength": 1,
          "examples": ["pnpm dev"]
        },
        "cwd": {
          "type": "string",
          "default": "."
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": ["name", "host", "target", "command"]
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "default": "docker"
        },
        "image": {
          "type": "string",
          "minLength": 1
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "volumes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "composeFile": {
          "type": "string"
        },
        "healthCheck": {
          "$ref": "#/$defs/healthCheck"
        }
      },
      "required": ["name", "image"]
    },
    "healthCheck": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["tcp", "http", "command"]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "host": {
          "type": "string",
          "default": "127.0.0.1"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "command": {
          "type": "string"
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1,
          "default": 30000
        }
      },
      "required": ["type"]
    }
  }
}
